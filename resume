    <!-- RE-ENGINEERED INTERACTIVE FILTER JAVASCRIPT -->
    <script>
        function filterSkillsGrid(tier) {
            // Manage Active Button States
            const pills = document.querySelectorAll('.filter-pill');
            pills.forEach(pill => pill.classList.remove('active'));
            event.target.classList.add('active');

            // Manage Target Card Structural Filters
            const structuralBoxes = document.querySelectorAll('.skill-progress-box');
            structuralBoxes.forEach(box => {
                if (tier === 'all') {
                    box.classList.remove('hidden');
                } else {
                    if (box.getAttribute('data-tier') === tier) {
                        box.classList.remove('hidden');
                    } else {
                        box.classList.add('hidden');
                    }
                }
            });
        }
    </script>
