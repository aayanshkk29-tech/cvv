        /* --- BRANDING & CSS VARIABLES --- */
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            --sidebar-bg: #111827;
            --card-bg: #ffffff;
            --text-main: #1f2937;
            --text-muted: #4b5563;
            --primary: #2563eb;       /* Electric Royal Blue */
